with "../../sdl3ada.gpr";

project Events_Smoke is

   for Languages use ("Ada");
   for Source_Dirs use (".");
   for Object_Dir use "../../obj/debug/events_smoke";
   for Exec_Dir use "../../bin";
   for Main use ("events_smoke.adb");

   package Builder is
      for Executable ("events_smoke.adb") use "events_smoke";
   end Builder;

   package Linker is
      case SDL3Ada.Platform is
         when "macosx" =>
            for Default_Switches ("Ada") use ("-F" & SDL3Ada.SDL3_Framework_Dir, "-Wl,-rpath," & SDL3Ada.SDL3_Framework_Dir);

         when others =>
            null;
      end case;
   end Linker;
end Events_Smoke;
