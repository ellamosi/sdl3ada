project Clear_SDLMain extends "../../../sdl3ada_sdlmain.gpr" is

   for Source_Dirs use (".", SDL3Ada_SDLMain.Support_Source_Dir);
   for Object_Dir use "../../../obj/debug/clear_sdlmain";
   for Exec_Dir use "../../../bin";
   for Main use ("sdl3ada_sdlmain.c");

   package Builder is
      for Executable ("sdl3ada_sdlmain.c") use "clear_sdlmain";
   end Builder;
end Clear_SDLMain;
