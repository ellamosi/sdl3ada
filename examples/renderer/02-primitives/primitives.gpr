with "../../../sdl3ada.gpr";

project Primitives is

   for Languages use ("Ada");
   for Source_Dirs use (".");
   for Object_Dir use "../../../obj/debug/primitives";
   for Exec_Dir use "../../../bin";
   for Main use ("primitives.adb");

   package Builder is
      for Executable ("primitives.adb") use "primitives";
   end Builder;

   package Linker is
      case SDL3Ada.Platform is
         when "macosx" =>
            for Default_Switches ("Ada") use ("-F" & SDL3Ada.SDL3_Framework_Dir, "-Wl,-rpath," & SDL3Ada.SDL3_Framework_Dir);

         when others =>
            null;
      end case;
   end Linker;
end Primitives;
